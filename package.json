{
  "name": "lotto-recommender",
  "version": "2.3.0",
  "description": "로또 당첨번호 분석 및 추천 앱",
  "main": "main.js",
  "author": "rlaeksxp3457",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir"
  },
  "build": {
    "appId": "com.lotto.recommender",
    "productName": "로또 추천기",
    "asar": true,
    "publish": {
      "provider": "github",
      "owner": "rlaeksxp3457",
      "repo": "lotto-recommender"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "signtoolOptions": {
        "sign": "./scripts/sign.js"
      },
      "signAndEditExecutable": true
    },
    "artifactName": "lotto-recommender-setup-${version}.${ext}",
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "ko-KR"
      ],
      "language": "1042",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerSidebar": "assets/installer-sidebar.bmp",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "로또 추천기"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "!src/renderer/**/*.map",
      "!backtest.js",
      "!lotto_analyzer.*",
      "!**/*.md"
    ],
    "extraResources": ["assets/tray-icon.png"],
    "directories": {
      "output": "dist"
    },
    "afterPack": "./scripts/afterPack.js"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  }
}
